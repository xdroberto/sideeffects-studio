# Sanity (CMS — currently unused but documented)
NEXT_PUBLIC_SANITY_PROJECT_ID=i1vskkfg
NEXT_PUBLIC_SANITY_DATASET=production

# Admin auth (LOCAL DEV ONLY — admin routes are excluded from production build)
# Generate ADMIN_PASSWORD_HASH with: node scripts/set-password.mjs <password>
# Keep unset/false in production. Admin UI, admin APIs, and internal pages
# return 404 unless this is exactly "true" outside NODE_ENV=production.
ENABLE_LOCAL_ADMIN=false
ADMIN_PASSWORD_HASH=
# Generate ADMIN_JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=
